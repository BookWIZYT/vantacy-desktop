{
  "name": "vantacy-desktop",
  "version": "1.0.0",
  "description": "Vantacy desktop coding agent companion",
  "main": "VantacyDesktop_Main.cjs",
  "author": "VANTA",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win nsis --publish never",
    "dist:mac": "electron-builder --mac dmg --publish never",
    "dist:linux": "electron-builder --linux AppImage --publish never"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ai.vanta.vantacy.desktop",
    "productName": "Vantacy Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "VantacyDesktop_UI.html",
      "VantacyDesktop_Main.cjs",
      "VantacyDesktop_Preload.cjs",
      "package.json"
    ],
    "asar": true,
    "npmRebuild": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vantacy Desktop"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "BookWIZYT",
      "repo": "vantacy-desktop",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  }
}
